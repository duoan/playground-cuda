{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure active cu",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CUDA_ARCHITECTURES=native",
                "-DDOWNLOAD_LIBTORCH=OFF",
                "-DTORCH_ROOT=${workspaceFolder}/libtorch"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "build active cu",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "${fileBasenameNoExtension}",
                "-j"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "configure active cu",
            "dependsOrder": "sequence",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run active cu",
            "type": "shell",
            "command": "${workspaceFolder}/build/${fileBasenameNoExtension}",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "LD_LIBRARY_PATH": "${workspaceFolder}/libtorch/lib:${env:LD_LIBRARY_PATH}"
                }
            },
            "dependsOn": "build active cu",
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "sync python env",
            "type": "shell",
            "command": "uv",
            "args": [
                "sync"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "run active py",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "python",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/python"
                }
            },
            "dependsOn": "sync python env",
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
