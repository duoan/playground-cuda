{
  "version": 4,
  "configurations": [
    {
      "name": "linux-gcc-x64",
      "compilerPath": "/usr/bin/gcc",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "includePath": [
        "${workspaceFolder}/src/cuda",
        "${workspaceFolder}/src/cuda/common",
        "/usr/local/cuda/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/src/cuda",
          "${workspaceFolder}/src/cuda/common",
          "/usr/local/cuda/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
